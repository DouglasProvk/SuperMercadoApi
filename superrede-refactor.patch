+++ b/supermercadoapi.client/src/pages/Caixa.tsx
@@ -1,12 +1,213 @@
-import React from 'react';
+import React, { useEffect, useState } from 'react';
+import apiService from '../services/api';
+import type { ProdutoDto, VendaDto, PagedResult } from '../types/index';
+import { useAuth } from '../contexts/AuthContext';
+
+interface CartItem { produto: ProdutoDto; quantidade: number; }
+
+const Caixa: React.FC = () => {
+  const { usuario } = useAuth();
+  const [produtos, setProdutos] = useState<ProdutoDto[]>([]);
+  const [busca, setBusca] = useState('');
+  const [cart, setCart] = useState<CartItem[]>([]);
+  const [vendaAtual, setVendaAtual] = useState<VendaDto | null>(null);
+  const [payModal, setPayModal] = useState(false);
+  const [payMethod, setPayMethod] = useState('Dinheiro');
+  const [toast, setToast] = useState('');
+  const [loading, setLoading] = useState(false);
+
+  useEffect(() => { loadProdutos(); }, []);
+
+  const loadProdutos = async (q = '') => {
+    try {
+      const r: PagedResult<ProdutoDto> = await apiService.getProdutos(1, 100, q || undefined);
+      setProdutos(r.dados.filter(p => p.ativo && p.quantidadeEstoque > 0));
+    } catch {}
+  };
+
+  const showToast = (msg: string) => { setToast(msg); setTimeout(() => setToast(''), 3000); };
+
+  const handleBusca = (v: string) => {
+    setBusca(v);
+    clearTimeout((handleBusca as any).__t);
+    (handleBusca as any).__t = setTimeout(() => loadProdutos(v), 300);
+  };
+
+  const addToCart = (p: ProdutoDto) => {
+    setCart(prev => {
+      const idx = prev.findIndex(c => c.produto.id === p.id);
+      if (idx >= 0) {
+        if (prev[idx].quantidade >= p.quantidadeEstoque) { showToast('Estoque insuficiente!'); return prev; }
+        return prev.map((c, i) => i === idx ? {...c, quantidade: c.quantidade + 1} : c);
+      }
+      return [...prev, { produto: p, quantidade: 1 }];
+    });
+  };
+
+  const changeQty = (id: number, delta: number) => {
+    setCart(prev => prev.map(c => {
+      if (c.produto.id !== id) return c;
+      const newQty = c.quantidade + delta;
+      if (newQty > c.produto.quantidadeEstoque) { showToast('Estoque insuficiente!'); return c; }
+      return newQty <= 0 ? null as any : {...c, quantidade: newQty};
+    }).filter(Boolean));
+  };
+
+  const removeFromCart = (id: number) => setCart(prev => prev.filter(c => c.produto.id !== id));
+
+  const total = cart.reduce((s, c) => s + c.produto.precoEfetivo * c.quantidade, 0);
+  const fmtBRL = (v: number) => `R$ ${v.toFixed(2).replace('.', ',')}`;
+
+  const openPay = async () => {
+    if (!cart.length) return;
+    setLoading(true);
+    try {
+      const venda: VendaDto = await apiService.abrirVenda({ supermercadoId: usuario?.supermercadoId ?? 1 });
+      for (const item of cart) {
+        await apiService.adicionarItem(venda.id, {
+          produtoId: item.produto.id,
+          quantidade: item.quantidade,
+          precoUnitario: null,
+          desconto: 0,
+        });
+      }
+      setVendaAtual(venda);
+      setPayModal(true);
+    } catch (e: any) {
+      showToast('ã ' + (e.response?.data?.message ?? e.message));
+    } finally { setLoading(false); }
+  };
+
+  const finalizar = async () => {
+    if (!vendaAtual) return;
+    try {
+      await apiService.finalizarVenda(vendaAtual.id, {
+        formaPagamento: payMethod,
+        valorPago: total,
+        desconto: 0,
+        acrescimo: 0,
+      });
+      setCart([]);
+      setVendaAtual(null);
+      setPayModal(false);
+      loadProdutos(busca);
+      showToast('ã Venda finalizada com sucesso!');
+    } catch (e: any) {
+      showToast('ã ' + (e.response?.data?.message ?? e.message));
+    }
+  };
+
+  const filtered = produtos.filter(p =>
+    !busca || p.nome.toLowerCase().includes(busca.toLowerCase()) || p.codigoBarras?.includes(busca)
+  );
 
-export const Caixa: React.FC = () => {
   return (
-    <div className="min-h-screen bg-gray-50 py-8">
-      <div className="max-w-6xl mx-auto px-4">
-        <h1 className="text-2xl font-bold text-gray-800 mb-2">Caixa (PDV)</h1>
-        <p className="text-sm text-gray-500 mb-6">Ponto de Venda em desenvolvimento</p>
+    <div>
+      {toast && <div style={{ position:'fixed', bottom:24, right:24, background:'#1a202c', color:'#fff', padding:'12px 18px', borderRadius:10, zIndex:200, fontSize:14 }}>{toast}</div>}
+
+      <div style={{ marginBottom:16 }}>
+        <div style={{ fontSize:26, fontWeight:800 }}>Caixa (PDV)</div>
